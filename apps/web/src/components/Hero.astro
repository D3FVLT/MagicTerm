---
import BrowserFrame from './BrowserFrame.astro';
import { SITE } from '~/data/site';
---

<section class="hero">
  <div class="hero__bg" aria-hidden="true"></div>

  <div class="hero__content">
    <a href={SITE.releasesUrl} target="_blank" rel="noopener" class="hero__badge">
      <span class="hero__badge-dot"></span>
      <span>v{SITE.version} is out — open the changelog</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M13 5l7 7-7 7"/>
      </svg>
    </a>

    <h1 class="hero__title">
      Your terminal,<br />
      <span class="text-gradient-accent">magically secure.</span>
    </h1>

    <p class="hero__subtitle">
      A fast, beautiful SSH/SFTP client. Credentials encrypted end-to-end on your device,
      synced across machines via Supabase. Free, open-source, and built with security from the ground up.
    </p>

    <div class="hero__cta">
      <a href="/download" class="btn-cta btn-cta--primary" id="hero-download">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>
        </svg>
        <span id="hero-download-label">Download</span>
      </a>
      <a href={SITE.githubUrl} target="_blank" rel="noopener" class="btn-cta btn-cta--ghost">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.69-3.87-1.54-3.87-1.54-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.24-1.27-5.24-5.66 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.45.11-3.02 0 0 .96-.31 3.16 1.17.92-.26 1.9-.39 2.88-.39.98 0 1.96.13 2.88.39 2.2-1.48 3.16-1.17 3.16-1.17.62 1.57.23 2.73.11 3.02.74.8 1.18 1.82 1.18 3.07 0 4.4-2.69 5.36-5.25 5.65.41.36.78 1.06.78 2.14 0 1.55-.01 2.79-.01 3.17 0 .31.21.68.8.56C20.71 21.39 24 17.07 24 12 24 5.65 18.85.5 12 .5z"/>
        </svg>
        <span>Star on GitHub</span>
      </a>
    </div>

    <div class="hero__platforms" aria-label="Available platforms">
      <span>Available for</span>
      <span class="hero__platform">macOS</span>
      <span class="hero__divider">·</span>
      <span class="hero__platform">Windows</span>
      <span class="hero__divider">·</span>
      <span class="hero__platform">Linux</span>
    </div>
  </div>

  <div class="hero__product">
    {/*
      SCREENSHOT REQUIRED — public/screenshots/vaults-midnight.png
      Exact frame: only the *content* of the Magic Term window (no macOS title bar,
      no traffic lights, no rounded corners — just the inside of the window).
      How to capture (macOS):
        1. Open Magic Term, switch to Midnight theme + Vaults page (the one shown in the design ref).
        2. Cmd+Shift+4, drag a tight rectangle starting just below the title bar
           ending right at the bottom edge of the window content.
        3. Save as `vaults-midnight.png` (PNG, no compression). 2x retina recommended:
           the source pixel size should be approximately 2400x1500.
        4. Drop into apps/web/public/screenshots/vaults-midnight.png.
      The site renders its own browser frame (traffic lights, header) around the image.
    */}
    <BrowserFrame
      src="/screenshots/vaults-midnight.png"
      alt="Magic Term Vaults page showing personal servers"
      tab="Vaults"
      glow
      loading="eager"
      class="hero__shot"
    />
  </div>
</section>

<script>
  const link = document.getElementById('hero-download') as HTMLAnchorElement | null;
  const label = document.getElementById('hero-download-label');
  if (link && label) {
    const ua = navigator.userAgent;
    let detected = '';
    if (/Mac/i.test(ua)) detected = 'macOS';
    else if (/Win/i.test(ua)) detected = 'Windows';
    else if (/Linux/i.test(ua)) detected = 'Linux';
    if (detected) {
      label.textContent = `Download for ${detected}`;
    }
  }
</script>

<style>
  .hero {
    position: relative;
    padding: 80px 24px 0;
    overflow: hidden;
    isolation: isolate;
  }

  @media (min-width: 768px) {
    .hero { padding: 120px 24px 0; }
  }

  .hero__bg {
    position: absolute;
    inset: -10% -10% 0;
    z-index: -1;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, color-mix(in oklab, var(--accent) 20%, transparent), transparent 70%),
      radial-gradient(ellipse 60% 40% at 20% 30%, color-mix(in oklab, var(--accent) 10%, transparent), transparent 60%);
    filter: blur(40px);
    animation: hero-bg-drift 14s ease-in-out infinite alternate;
  }

  @keyframes hero-bg-drift {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(20px, -10px) scale(1.05); }
  }

  .hero__content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    animation: fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    border-radius: 999px;
    background: color-mix(in oklab, var(--accent) 10%, transparent);
    border: 1px solid color-mix(in oklab, var(--accent) 25%, transparent);
    color: var(--accent);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    margin-bottom: 32px;
    transition: all 0.2s ease;
  }

  .hero__badge:hover {
    background: color-mix(in oklab, var(--accent) 15%, transparent);
    transform: translateY(-1px);
  }

  .hero__badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent) 25%, transparent);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .hero__title {
    font-size: clamp(40px, 7vw, 84px);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--fg);
    margin: 0 0 24px;
  }

  .hero__subtitle {
    color: var(--fg-muted);
    font-size: clamp(16px, 2vw, 20px);
    line-height: 1.5;
    max-width: 620px;
    margin: 0 auto 40px;
  }

  .hero__cta {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .btn-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 50px;
    padding: 0 24px;
    border-radius: 12px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-cta--primary {
    background: var(--accent);
    color: var(--accent-fg);
    box-shadow: 0 8px 24px -8px color-mix(in oklab, var(--accent) 60%, transparent);
  }

  .btn-cta--primary:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
    box-shadow: 0 12px 32px -8px color-mix(in oklab, var(--accent) 70%, transparent);
  }

  .btn-cta--ghost {
    background: var(--surface-2);
    color: var(--fg);
    border: 1px solid var(--border);
  }

  .btn-cta--ghost:hover {
    background: var(--surface-3);
    transform: translateY(-1px);
  }

  .hero__platforms {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--fg-subtle);
    font-size: 13px;
  }

  .hero__platform {
    color: var(--fg-muted);
    font-weight: 500;
  }

  .hero__divider {
    color: var(--fg-subtle);
  }

  .hero__product {
    max-width: 1100px;
    margin: 80px auto 0;
    padding: 0 24px;
    animation: fade-up 1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
  }

  .hero__shot {
    transform: perspective(2000px) rotateX(8deg);
    transform-origin: center top;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero__shot:hover {
    transform: perspective(2000px) rotateX(2deg);
  }

  @media (max-width: 640px) {
    .hero__shot { transform: none; }
    .hero__shot:hover { transform: none; }
  }
</style>
