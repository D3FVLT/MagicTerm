---
import Base from '~/layouts/Base.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';

// Supabase env vars are read at build time (Astro inlines anything prefixed
// with PUBLIC_). They're public-safe — the anon key only allows operations
// permitted by Row Level Security.
const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
const isConfigured = Boolean(SUPABASE_URL && SUPABASE_ANON_KEY);
---

<Base
  title="Reset password"
  description="Set a new password for your Magic Term account."
  noindex
>
  <Header />
  <main class="auth">
    <div
      class="auth__card"
      id="reset-root"
      data-supabase-url={SUPABASE_URL}
      data-supabase-anon-key={SUPABASE_ANON_KEY}
      data-configured={isConfigured ? 'true' : 'false'}
    >
      <h1>Reset your password</h1>
      <p class="auth__lead">
        Choose a new password for your Magic Term account. Note: this changes only your account
        password (used to sign in to the cloud). Your <strong>master password</strong> — the one
        that encrypts your vault — is separate and is only stored on your device.
      </p>

      {!isConfigured && (
        <div class="auth__error">
          The reset form is not configured for this deployment. Open the Magic Term app and use
          its <em>Forgot password?</em> link, or contact support.
        </div>
      )}

      <div id="reset-loading" class="auth__loading" hidden>
        <span class="auth__spinner"></span>
        <span>Validating reset link…</span>
      </div>

      <form
        id="reset-form"
        class="auth__form"
        hidden={!isConfigured}
        onsubmit="return false"
        novalidate
      >
        <label class="auth__field">
          <span>New password</span>
          <input
            id="new-password"
            type="password"
            autocomplete="new-password"
            required
            minlength="6"
            placeholder="At least 6 characters"
            disabled
          />
        </label>
        <label class="auth__field">
          <span>Confirm new password</span>
          <input
            id="confirm-password"
            type="password"
            autocomplete="new-password"
            required
            minlength="6"
            placeholder="Repeat the password"
            disabled
          />
        </label>

        <div id="reset-error" class="auth__error" hidden></div>
        <div id="reset-success" class="auth__success" hidden>
          <strong>Password updated.</strong> You can close this tab and sign in to Magic Term with the new password.
        </div>

        <button id="reset-submit" type="button" class="auth__primary" disabled>
          Update password
        </button>
      </form>

      <p class="auth__footnote">
        Trouble? <a href="mailto:hi@magicterm.app?subject=Password reset issue">Contact us</a>.
      </p>
    </div>
  </main>
  <Footer />
</Base>

<script>
  // NOTE: This script is intentionally NOT marked is:inline / define:vars —
  // we want Astro/Vite to bundle it so the bare-module import below resolves
  // correctly. Earlier we used define:vars + dynamic import('@supabase/...')
  // which made the script inline; in inline scripts a bare specifier like
  // '@supabase/supabase-js' cannot be resolved by the browser, the script
  // throws, and the form silently falls back to a native HTML POST (which is
  // why the page just reloaded with no effect).
  import { createClient, type SupabaseClient } from '@supabase/supabase-js';

  const root = document.getElementById('reset-root') as HTMLElement | null;
  if (root && root.dataset.configured === 'true') {
    const SUPABASE_URL = root.dataset.supabaseUrl ?? '';
    const SUPABASE_ANON_KEY = root.dataset.supabaseAnonKey ?? '';

    const form = document.getElementById('reset-form') as HTMLFormElement | null;
    const newEl = document.getElementById('new-password') as HTMLInputElement | null;
    const confirmEl = document.getElementById('confirm-password') as HTMLInputElement | null;
    const errorEl = document.getElementById('reset-error') as HTMLElement | null;
    const successEl = document.getElementById('reset-success') as HTMLElement | null;
    const submit = document.getElementById('reset-submit') as HTMLButtonElement | null;
    const loadingEl = document.getElementById('reset-loading') as HTMLElement | null;

    const setLoading = (on: boolean) => {
      if (loadingEl) loadingEl.hidden = !on;
    };

    const showError = (msg: string) => {
      console.warn('[reset-password]', msg);
      if (!errorEl) return;
      errorEl.textContent = msg;
      errorEl.hidden = false;
    };

    const enableForm = () => {
      if (newEl) newEl.disabled = false;
      if (confirmEl) confirmEl.disabled = false;
      if (submit) submit.disabled = false;
      newEl?.focus();
    };

    const supabase: SupabaseClient = createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
      auth: {
        // We handle URL params manually below — different Supabase email
        // links produce different formats and detectSessionInUrl only
        // handles a subset.
        detectSessionInUrl: false,
        persistSession: false,
        autoRefreshToken: false,
      },
    });

    /**
     * Establish a Supabase session from whichever auth params are present in
     * the URL. Supabase password-reset links can arrive in three shapes:
     *  1. `?token_hash=...&type=recovery`   (default modern format)
     *  2. `?code=...`                       (PKCE; only works if the verifier
     *                                        is in this browser's storage —
     *                                        usually fails when the request
     *                                        was made from the desktop app)
     *  3. `#access_token=...&refresh_token=...&type=recovery` (legacy
     *     implicit flow)
     */
    async function bootstrapSession(): Promise<{ ok: true } | { ok: false; reason: string }> {
      const url = new URL(window.location.href);
      const hash = new URLSearchParams(window.location.hash.replace(/^#/, ''));

      const errorDescription =
        url.searchParams.get('error_description') ?? hash.get('error_description');
      if (errorDescription) {
        return { ok: false, reason: decodeURIComponent(errorDescription) };
      }

      const tokenHash = url.searchParams.get('token_hash') ?? hash.get('token_hash');
      const type = url.searchParams.get('type') ?? hash.get('type');
      const code = url.searchParams.get('code');
      const accessToken = hash.get('access_token');
      const refreshToken = hash.get('refresh_token');

      if (tokenHash && (type === 'recovery' || !type)) {
        const { error } = await supabase.auth.verifyOtp({
          token_hash: tokenHash,
          type: 'recovery',
        });
        if (error) return { ok: false, reason: error.message };
        return { ok: true };
      }

      if (accessToken && refreshToken) {
        const { error } = await supabase.auth.setSession({
          access_token: accessToken,
          refresh_token: refreshToken,
        });
        if (error) return { ok: false, reason: error.message };
        return { ok: true };
      }

      if (code) {
        const { error } = await supabase.auth.exchangeCodeForSession(code);
        if (error) {
          // PKCE without local code_verifier — common when the reset was
          // requested from the desktop app and the link is opened in a
          // different browser. Fall through to a clear error.
          return {
            ok: false,
            reason:
              'This reset link uses a flow that requires the same browser that requested it. Please open the link in the same browser, or request a new reset from the app.',
          };
        }
        return { ok: true };
      }

      return {
        ok: false,
        reason:
          'No reset token found in the URL. Open the link from the email exactly as it was sent.',
      };
    }

    setLoading(true);
    void bootstrapSession()
      .then((result) => {
        setLoading(false);
        if (!result.ok) {
          showError(result.reason);
          return;
        }
        enableForm();
        // Strip auth params from the URL so a refresh doesn't replay them.
        try {
          history.replaceState(null, '', window.location.pathname);
        } catch {
          /* ignore */
        }
      })
      .catch((err: unknown) => {
        setLoading(false);
        const msg = err instanceof Error ? err.message : 'Unknown error';
        showError(`Could not validate reset link: ${msg}`);
      });

    const handleUpdate = async () => {
      if (errorEl) errorEl.hidden = true;
      const next = newEl?.value ?? '';
      const confirm = confirmEl?.value ?? '';

      if (next.length < 6) {
        showError('Password must be at least 6 characters.');
        return;
      }
      if (next !== confirm) {
        showError('Passwords do not match.');
        return;
      }

      if (submit) submit.disabled = true;
      try {
        const { error } = await supabase.auth.updateUser({ password: next });
        if (error) {
          showError(error.message);
          if (submit) submit.disabled = false;
          return;
        }
        if (form) form.hidden = true;
        if (successEl) successEl.hidden = false;
        // Burn the recovery session so a refresh doesn't keep us "logged in" here.
        await supabase.auth.signOut().catch(() => {});
      } catch (err: unknown) {
        const msg = err instanceof Error ? err.message : 'Unknown error';
        showError(`Failed to update password: ${msg}`);
        if (submit) submit.disabled = false;
      }
    };

    submit?.addEventListener('click', (e) => {
      e.preventDefault();
      void handleUpdate();
    });

    // Allow Enter-to-submit from either input.
    [newEl, confirmEl].forEach((el) => {
      el?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          void handleUpdate();
        }
      });
    });
  }
</script>

<style>
  .auth {
    max-width: 480px;
    margin: 0 auto;
    padding: 80px 24px 0;
  }

  .auth__card {
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 40px 32px;
  }

  h1 {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--fg);
    margin: 0 0 12px;
  }

  .auth__lead {
    color: var(--fg-muted);
    font-size: 14px;
    line-height: 1.55;
    margin: 0 0 24px;
  }

  .auth__lead strong { color: var(--fg); font-weight: 600; }

  .auth__form {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .auth__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .auth__field span {
    font-size: 13px;
    color: var(--fg-muted);
    font-weight: 500;
  }

  .auth__field input {
    height: 42px;
    padding: 0 14px;
    border-radius: 8px;
    border: 1px solid var(--border-strong);
    background: var(--bg);
    color: var(--fg);
    font-size: 14px;
    font-family: var(--font-sans);
    outline: none;
    transition: border-color 0.15s ease;
  }

  .auth__field input:focus {
    border-color: var(--accent);
  }

  .auth__field input:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .auth__primary {
    height: 44px;
    border-radius: 10px;
    background: var(--accent);
    color: var(--accent-fg);
    border: 0;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    margin-top: 8px;
    transition: background 0.15s ease;
  }

  .auth__primary:hover:not(:disabled) { background: var(--accent-hover); }
  .auth__primary:disabled { opacity: 0.5; cursor: not-allowed; }

  .auth__loading {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--fg-muted);
    font-size: 13px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px 14px;
    margin-bottom: 14px;
  }

  .auth__spinner {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid var(--border-strong);
    border-top-color: var(--accent);
    animation: spin 0.8s linear infinite;
    display: inline-block;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .auth__error {
    background: color-mix(in oklab, var(--danger) 10%, transparent);
    border: 1px solid color-mix(in oklab, var(--danger) 30%, transparent);
    color: var(--danger);
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 13px;
    line-height: 1.45;
  }

  .auth__success {
    background: color-mix(in oklab, var(--success) 10%, transparent);
    border: 1px solid color-mix(in oklab, var(--success) 30%, transparent);
    color: var(--success);
    border-radius: 8px;
    padding: 14px;
    font-size: 14px;
    line-height: 1.45;
  }

  .auth__success strong { display: block; margin-bottom: 4px; }

  .auth__footnote {
    color: var(--fg-subtle);
    font-size: 12px;
    text-align: center;
    margin: 24px 0 0;
  }

  .auth__footnote a {
    color: var(--accent);
    text-decoration: none;
  }
</style>
