---
import Base from '~/layouts/Base.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';

// Supabase env vars are read at build time (Astro inlines anything prefixed
// with PUBLIC_). They're public-safe — the anon key only allows operations
// permitted by Row Level Security.
const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
const isConfigured = Boolean(SUPABASE_URL && SUPABASE_ANON_KEY);
---

<Base
  title="Reset password"
  description="Set a new password for your Magic Term account."
  noindex
>
  <Header />
  <main class="auth">
    <div class="auth__card">
      <h1>Reset your password</h1>
      <p class="auth__lead">
        Choose a new password for your Magic Term account. Note: this changes only your account
        password (used to sign in to the cloud). Your <strong>master password</strong> — the one
        that encrypts your vault — is separate and is only stored on your device.
      </p>

      {!isConfigured && (
        <div class="auth__error">
          The reset form is not configured for this deployment. Open the Magic Term app and use
          its <em>Forgot password?</em> link, or contact support.
        </div>
      )}

      <form id="reset-form" class="auth__form" hidden={!isConfigured}>
        <label class="auth__field">
          <span>New password</span>
          <input
            id="new-password"
            type="password"
            autocomplete="new-password"
            required
            minlength="6"
            placeholder="At least 6 characters"
          />
        </label>
        <label class="auth__field">
          <span>Confirm new password</span>
          <input
            id="confirm-password"
            type="password"
            autocomplete="new-password"
            required
            minlength="6"
            placeholder="Repeat the password"
          />
        </label>

        <div id="reset-error" class="auth__error" hidden></div>
        <div id="reset-success" class="auth__success" hidden>
          <strong>Password updated.</strong> You can close this tab and sign in to Magic Term with the new password.
        </div>

        <button id="reset-submit" type="submit" class="auth__primary">
          Update password
        </button>
      </form>

      <p class="auth__footnote">
        Trouble? <a href={`mailto:hi@magicterm.app?subject=Password reset issue`}>Contact us</a>.
      </p>
    </div>
  </main>
  <Footer />
</Base>

<script define:vars={{ SUPABASE_URL, SUPABASE_ANON_KEY, isConfigured }}>
  if (isConfigured) {
    import('@supabase/supabase-js').then(({ createClient }) => {
      const supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
        auth: { detectSessionInUrl: true, persistSession: true, autoRefreshToken: true },
      });

      const form = document.getElementById('reset-form');
      const newEl = document.getElementById('new-password');
      const confirmEl = document.getElementById('confirm-password');
      const errorEl = document.getElementById('reset-error');
      const successEl = document.getElementById('reset-success');
      const submit = document.getElementById('reset-submit');

      const showError = (msg) => {
        if (!errorEl) return;
        errorEl.textContent = msg;
        errorEl.hidden = false;
      };

      // Supabase auto-detects the recovery link from the URL hash and signs the
      // user in for the duration of this page. If we don't have a session, the
      // link is invalid or expired.
      let hasSession = false;
      supabase.auth.onAuthStateChange((event, session) => {
        if (event === 'PASSWORD_RECOVERY' || (event === 'INITIAL_SESSION' && session)) {
          hasSession = !!session;
        }
      });

      // Give Supabase a moment to process the hash before we trust the lack of session.
      setTimeout(async () => {
        const { data } = await supabase.auth.getSession();
        hasSession = !!data.session;
        if (!hasSession) {
          showError(
            'This reset link is invalid or has expired. Request a new one from the app.'
          );
          if (submit) submit.setAttribute('disabled', 'disabled');
        }
      }, 500);

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (errorEl) errorEl.hidden = true;
        const next = (newEl && 'value' in newEl ? newEl.value : '') || '';
        const confirm = (confirmEl && 'value' in confirmEl ? confirmEl.value : '') || '';

        if (next.length < 6) {
          showError('Password must be at least 6 characters.');
          return;
        }
        if (next !== confirm) {
          showError('Passwords do not match.');
          return;
        }
        if (!hasSession) {
          showError('Reset link is invalid or expired. Request a new one from the app.');
          return;
        }

        if (submit) submit.setAttribute('disabled', 'disabled');
        const { error } = await supabase.auth.updateUser({ password: next });
        if (error) {
          showError(error.message);
          if (submit) submit.removeAttribute('disabled');
          return;
        }

        if (form) form.hidden = true;
        if (successEl) successEl.hidden = false;
        // Sign the recovery session out so refreshing the page doesn't keep the user "logged in" here.
        await supabase.auth.signOut();
      });
    });
  }
</script>

<style>
  .auth {
    max-width: 480px;
    margin: 0 auto;
    padding: 80px 24px 0;
  }

  .auth__card {
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 40px 32px;
  }

  h1 {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--fg);
    margin: 0 0 12px;
  }

  .auth__lead {
    color: var(--fg-muted);
    font-size: 14px;
    line-height: 1.55;
    margin: 0 0 24px;
  }

  .auth__lead strong { color: var(--fg); font-weight: 600; }

  .auth__form {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .auth__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .auth__field span {
    font-size: 13px;
    color: var(--fg-muted);
    font-weight: 500;
  }

  .auth__field input {
    height: 42px;
    padding: 0 14px;
    border-radius: 8px;
    border: 1px solid var(--border-strong);
    background: var(--bg);
    color: var(--fg);
    font-size: 14px;
    font-family: var(--font-sans);
    outline: none;
    transition: border-color 0.15s ease;
  }

  .auth__field input:focus {
    border-color: var(--accent);
  }

  .auth__primary {
    height: 44px;
    border-radius: 10px;
    background: var(--accent);
    color: var(--accent-fg);
    border: 0;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    margin-top: 8px;
    transition: background 0.15s ease;
  }

  .auth__primary:hover { background: var(--accent-hover); }
  .auth__primary:disabled { opacity: 0.5; cursor: not-allowed; }

  .auth__error {
    background: color-mix(in oklab, var(--danger) 10%, transparent);
    border: 1px solid color-mix(in oklab, var(--danger) 30%, transparent);
    color: var(--danger);
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 13px;
    line-height: 1.45;
  }

  .auth__success {
    background: color-mix(in oklab, var(--success) 10%, transparent);
    border: 1px solid color-mix(in oklab, var(--success) 30%, transparent);
    color: var(--success);
    border-radius: 8px;
    padding: 14px;
    font-size: 14px;
    line-height: 1.45;
  }

  .auth__success strong { display: block; margin-bottom: 4px; }

  .auth__footnote {
    color: var(--fg-subtle);
    font-size: 12px;
    text-align: center;
    margin: 24px 0 0;
  }

  .auth__footnote a {
    color: var(--accent);
    text-decoration: none;
  }
</style>
