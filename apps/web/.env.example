# Public-safe values. Astro inlines anything prefixed with PUBLIC_ at build
# time. Both of these are 100% OK to commit and ship in client-side code:
# Supabase RLS policies (see supabase/security-hardening.sql) are what
# actually guards your data, not key secrecy.
#
# Copy this file to `.env` in the same directory and fill in the values.

PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
