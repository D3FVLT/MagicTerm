{
  "name": "@magicterm/desktop",
  "version": "0.1.0",
  "description": "Cross-platform SSH/SFTP client with E2E encryption",
  "author": "MagicTerm",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/D3FVLT/MagicTerm.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rm -rf dist out",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "@magicterm/crypto": "workspace:*",
    "@magicterm/shared": "workspace:*",
    "@magicterm/supabase-client": "workspace:*",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "ssh2": "^1.15.0"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ssh2": "^1.15.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.2.0",
    "postcss": "^8.4.38",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  }
}
